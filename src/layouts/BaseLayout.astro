---
import '../styles/global.css';
import { SITE, FAQ_ITEMS, CHEAT_MODULES, META_KEYWORDS } from '../data/seo';
import { OG_IMAGE } from '../data/images';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(`/images/${OG_IMAGE.filename}`, Astro.site);
const logoURL = new URL('/logo.svg', Astro.site);
const faviconPNG = new URL('/favicon-192x192.png', Astro.site);

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'ValorantCheats',
  alternateName: ['Valorant Cheats', 'valorantcheats.org'],
  url: SITE.url,
  logo: {
    '@type': 'ImageObject',
    url: faviconPNG.href,
    width: 192,
    height: 192,
    caption: 'ValorantCheats.org',
  },
  description: SITE.description,
  sameAs: [SITE.url],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Valorant Cheats',
  alternateName: 'ValorantCheats.org',
  url: SITE.url,
  description: SITE.description,
  inLanguage: 'en-US',
  publisher: { '@type': 'Organization', name: 'ValorantCheats' },
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description: description,
  url: canonicalURL.href,
  isPartOf: { '@type': 'WebSite', url: SITE.url, name: 'Valorant Cheats' },
  about: { '@type': 'Thing', name: 'Valorant Cheats' },
  datePublished: SITE.published,
  dateModified: SITE.modified,
  inLanguage: 'en-US',
  primaryImageOfPage: {
    '@type': 'ImageObject',
    url: ogImageURL.href,
    caption: OG_IMAGE.alt,
  },
};

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Valorant Cheats',
  applicationCategory: 'GameApplication',
  operatingSystem: 'Windows 10, Windows 11',
  description:
    'Undetected Valorant cheats with aimbot, ESP, wallhack, triggerbot, radar hack, recoil control, skin changer, and HWID spoofer. Bypasses Riot Vanguard.',
  url: SITE.url,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    description: 'Free 24-hour Valorant cheats trial',
    availability: 'https://schema.org/InStock',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    ratingCount: '2847',
    bestRating: '5',
    worstRating: '1',
  },
  author: organizationSchema,
};

const cheatListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Valorant Cheats — Full Module List',
  description: 'Every cheat included in the ValorantCheats.org suite',
  itemListElement: CHEAT_MODULES.map((mod, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: mod.name,
    description: mod.description,
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Valorant Cheats', item: canonicalURL.href },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={META_KEYWORDS} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content={SITE.author} />
    <meta name="theme-color" content="#0d0d0f" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Valorant Cheats" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:image:secure_url" content={ogImageURL.href} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="3840" />
    <meta property="og:image:height" content="2160" />
    <meta property="og:image:alt" content={OG_IMAGE.alt} />
    <meta property="og:locale" content={SITE.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />
    <meta name="twitter:image:alt" content={OG_IMAGE.alt} />

    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" as="image" href="/images/hero.jpg" fetchpriority="high" />

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(cheatListSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <slot />
  </body>
</html>
